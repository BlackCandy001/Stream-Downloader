{
  "name": "stream-downloader",
  "version": "1.0.0",
  "description": "Desktop application for downloading HLS/DASH/MSS video streams",
  "main": "dist-electron/main.js",
  "type": "module",
  "author": "Black Candy",
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "electron:dev": "node scripts/electron-dev.js",
    "build": "tsc && vite build",
    "electron:build": "npm run build && node scripts/compile-electron.js && electron-builder",
    "lint": "eslint src --ext ts,tsx",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\""
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/react": "^18.2.48",
    "@types/react-dom": "^18.2.18",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "@vitejs/plugin-react": "^4.2.1",
    "antd": "^5.13.2",
    "dayjs": "^1.11.10",
    "electron": "^28.1.0",
    "electron-builder": "^24.9.1",
    "eslint": "^8.56.0",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "i18next": "^23.8.2",
    "playwright": "^1.41.0",
    "prettier": "^3.2.4",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-i18next": "^14.0.5",
    "react-router-dom": "^6.21.3",
    "styled-components": "^6.1.8",
    "typescript": "^5.3.3",
    "vite": "^5.0.12",
    "vite-plugin-electron": "^0.28.2",
    "vitest": "^1.2.1",
    "zustand": "^4.5.0"
  },
  "dependencies": {
    "@distube/ytdl-core": "^4.16.12",
    "fluent-ffmpeg": "^2.1.3",
    "m3u8-parser": "^7.2.0",
    "node-fetch": "^3.3.2"
  }
}
